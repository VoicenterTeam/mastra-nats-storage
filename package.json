{
  "name": "@voicenter/mastra-nats-storage",
  "version": "0.1.0",
  "description": "NATS JetStream KV storage adapter for Mastra workflows",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/VoicenterTeam/mastra-nats-storage"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run test/unit/",
    "test:integration": "vitest run test/integration/",
    "test:mastra": "vitest run test/mastra/",
    "test:watch": "vitest watch",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "@mastra/core": "^1.0.0"
  },
  "dependencies": {
    "@nats-io/kv": "^3.0.0",
    "@nats-io/transport-node": "^3.0.0"
  },
  "devDependencies": {
    "@mastra/core": "^1.0.0",
    "@mastra/libsql": "^1.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0",
    "zod": "^3.23.0"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mastra",
    "nats",
    "jetstream",
    "kv",
    "storage",
    "workflow",
    "ai"
  ]
}
